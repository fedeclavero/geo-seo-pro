{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "{{NOMBRE_SITIO}}",
  "url": "{{URL_SITIO}}",
  "description": "{{DESCRIPCION_SITIO}}",
  "inLanguage": "es",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "{{URL_BUSQUEDA}}?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{NOMBRE_EMPRESA}}",
    "url": "{{URL_SITIO}}"
  }
}
